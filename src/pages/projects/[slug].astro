---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.name} — Cole Steele`}>
  <Navigation />
  <main id="main-content" tabindex="-1" class="pt-28 md:pt-32 pb-16 max-w-5xl mx-auto px-5 md:px-12">
    <a
      id="back-btn"
      href="/"
      class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-white hover:opacity-90 transition-opacity duration-200 mb-8"
    >
      ← Back
    </a>

    {project.image && (
      <div class={`${project.slug === 'personal-site' ? 'project-img-frame ' : ''}w-full max-w-xl md:w-1/2 rounded-2xl overflow-hidden mb-3 bg-[var(--card-bg)] aspect-[16/10] md:aspect-auto md:h-60`}>
        <img
          src={project.image}
          alt={`${project.name} preview`}
          class={project.imageClass ?? "w-full h-full object-cover object-center"}
          style={project.imageStyle}
        />
      </div>
    )}

    {project.url ? (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-start gap-2 mb-4"
      >
        <h1 class="font-display text-3xl md:text-5xl font-black leading-tight text-[var(--text)] group-hover:text-[var(--accent)] transition-colors duration-200">
          {project.name}
        </h1>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6 md:w-7 md:h-7 flex-shrink-0 mt-2 md:mt-3 text-[var(--accent)] opacity-0 translate-x-[-4px] translate-y-[4px] group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0 transition-all duration-200">
          <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 0 0-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 0 0 .75-.75v-4a.75.75 0 0 1 1.5 0v4A2.25 2.25 0 0 1 12.75 17h-8.5A2.25 2.25 0 0 1 2 14.75v-8.5A2.25 2.25 0 0 1 4.25 4h5a.75.75 0 0 1 0 1.5h-5Z" clip-rule="evenodd" />
          <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 0 0 1.06.053L16.5 4.44v2.81a.75.75 0 0 0 1.5 0v-4.5a.75.75 0 0 0-.75-.75h-4.5a.75.75 0 0 0 0 1.5h2.553l-9.056 8.194a.75.75 0 0 0-.053 1.06Z" clip-rule="evenodd" />
        </svg>
      </a>
    ) : (
      <h1 class="font-display text-3xl md:text-5xl font-black leading-tight text-[var(--text)] mb-4">
        {project.name}
      </h1>
    )}

    <div class="flex flex-wrap gap-2 mb-6">
      {project.tags.map((tag) => (
        <span class="text-xs bg-[var(--card-bg)] text-[var(--muted)] px-3 py-1 rounded-full cursor-default select-none transition-all duration-200 hover:bg-[var(--accent)] hover:text-white">{tag}</span>
      ))}
    </div>

    <div class="flex gap-4 mb-10">
      {project.github && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--accent)] px-5 py-2 text-sm font-medium text-white hover:opacity-90 transition-opacity duration-200"
        >
          GitHub
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd" />
          </svg>
        </a>
      )}
      {!project.github && project.githubDisabled && (
        <span class="inline-flex items-center gap-2 rounded-full bg-[var(--card-bg)] px-5 py-2 text-sm font-medium text-[var(--muted)] opacity-40 cursor-not-allowed select-none">
          GitHub
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--card-bg)] px-5 py-2 text-sm font-medium text-[var(--text)] hover:opacity-90 transition-opacity duration-200"
        >
          Live Demo
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd" />
          </svg>
        </a>
      )}
      {!project.demo && project.demoDisabled && (
        <span class="inline-flex items-center gap-2 rounded-full bg-[var(--card-bg)] px-5 py-2 text-sm font-medium text-[var(--muted)] opacity-40 cursor-not-allowed select-none">
          Live Demo
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
    </div>

    <div class="mb-10 max-w-2xl space-y-8">
      <div>
        <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--accent)] mb-3">Project Description</h2>
        <div class="text-[var(--muted)] leading-relaxed space-y-4" set:html={project.longDescription} />
      </div>
      {project.technicalDescription && (
        <div>
          <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--accent)] mb-3">Stack</h2>
          <div class="text-[var(--muted)] leading-relaxed space-y-4" set:html={project.technicalDescription} />
        </div>
      )}
    </div>
  </main>

<style>
  .project-img-frame {
    position: relative;
  }

  .project-img-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 35%, rgba(0,0,0,0.55) 100%);
  }
</style>

<script>
  document.getElementById('back-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    const cameFromSite = document.referrer && document.referrer.includes(window.location.origin);
    if (cameFromSite) {
      sessionStorage.setItem('scrollTo', 'projects');
    }
    window.location.href = '/';
  });
</script>
</Layout>
