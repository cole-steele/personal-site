---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Cole Steele' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&family=Plus+Jakarta+Sans:wght@800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #e8e4dc;
    --bg2: #dedad0;
    --text: #1a1a18;
    --muted: #6b6860;
    --accent: #c4922a;
    --accent-light: #e8b84b;
    --link: #2a7abf;
    --card-bg: #f0ece3;
    --nav-pill: #1a1a18;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
  }

  section, [id] {
    scroll-margin-top: 80px;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: var(--accent);
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 0 0 6px 6px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    z-index: 9999;
  }

  .skip-link:focus {
    top: 0;
  }

  *:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
</style>
