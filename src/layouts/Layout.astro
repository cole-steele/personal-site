---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Cole Steele | Software Engineer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&family=Plus+Jakarta+Sans:wght@800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link" id="skip-link">Skip to content</a>
    <slot />
    <script>
      document.getElementById('skip-link')?.addEventListener('click', (event) => {
        const target = document.getElementById('main-content');
        if (!target) return;

        event.preventDefault();
        target.focus({ preventScroll: true });
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', '#main-content');
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #e8e4dc;
    --bg2: #dedad0;
    --text: #1a1a18;
    --muted: #6b6860;
    --accent: #c4922a;
    --accent-light: #e8b84b;
    --link: #2a7abf;
    --card-bg: #f0ece3;
    --nav-pill: #1a1a18;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
  }

  section, [id] {
    scroll-margin-top: 80px;
  }

  .skip-link {
    position: fixed;
    top: 0;
    left: 50%;
    background: var(--accent);
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 0 0 6px 6px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transform: translate(-50%, -120%);
    transition: transform 0.15s ease;
    z-index: 9999;
  }

  .skip-link:focus-visible {
    transform: translate(-50%, 0);
  }

  *:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
</style>
