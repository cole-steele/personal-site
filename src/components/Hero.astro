<section class="mt-16 grid grid-cols-2 gap-16 max-w-5xl mx-auto px-12 pb-12 items-center" id="main-content" tabindex="-1" aria-label="About">
  <div class="hero-text">
    <h1 class="font-display text-4xl md:text-6xl font-black leading-tight text-[var(--text)] mb-1">
      Cole Steele
    </h1>
    <p class="text-lg text-[var(--muted)] mb-3 font-light">
      Software Engineer <span class="mx-2 opacity-40">|</span> Minneapolis, MN
    </p>
    <p class="text-sm text-[var(--muted)] leading-loose max-w-sm mb-5">
      I build web applications and have hands-on experience managing systems, networks, and devices in production environments. Currently working as an IT Specialist while actively seeking software engineering and IT roles.
    </p>
    <div class="flex items-center gap-2 mb-5">
      <span class="availability-dot"></span>
      <span class="text-xs text-green-500 font-medium">Open to work!</span>
    </div>

    <div class="divider mb-6"></div>

    <div class="flex items-center gap-3 flex-wrap">
      <div class="email-wrapper">
        <button
          id="copy-email-hero"
          aria-label="Copy email address to clipboard"
          class="contact-btn text-sm text-[var(--muted)] hover:text-[var(--accent)] transition-colors duration-200 cursor-pointer bg-transparent border-none p-0"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="contact-icon w-4 h-4 flex-shrink-0">
            <path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3Z" />
            <path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839Z" />
          </svg>
          <span class="contact-text">cole.steele.dev@gmail.com</span>
          <span class="contact-text-short">cole.steele.dev@gmail.com</span>
        </button>
        <div id="copied-tooltip-hero" class="tooltip" style="opacity: 0;" role="status" aria-live="polite">Copied!</div>
      </div>
      <span class="contact-sep w-px h-4 bg-[var(--muted)] opacity-40" aria-hidden="true"></span>
      <a
        href="https://github.com/cole-steele"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile (opens in new tab)"
        class="contact-btn text-sm text-[var(--muted)] hover:text-[var(--accent)] transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="contact-icon w-4 h-4 flex-shrink-0">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z" />
        </svg>
        <span class="contact-text">GitHub</span>
        <span class="contact-text-short">GitHub</span>
      </a>
      <span class="contact-sep w-px h-4 bg-[var(--muted)] opacity-40" aria-hidden="true"></span>
      <span class="flex-break" aria-hidden="true"></span>
      <a
        href="/resume.pdf"
        download
        class="rounded-full bg-[var(--accent)] px-4 py-1.5 text-xs font-medium text-white hover:bg-[var(--accent-light)] transition-all duration-300"
      >
        Download Resume
      </a>
    </div>
  </div>

  <div class="photo-card">
    <div class="photo-wrapper relative flex-shrink-0" data-photo-wrapper>
      <div class="gold-card absolute inset-0 rounded-2xl bg-gradient-to-b from-[#e8b84b] to-[#c4922a] z-0"></div>
      <img
        src="/headshot.png"
        alt="Cole Steele"
        class="relative z-10 w-full rounded-2xl object-cover object-top"
      />
    </div>
  </div>
</section>

<style>
  @media (max-width: 720px) {
    section {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1.25rem 4rem;
      margin-top: 0.75rem;
    }

    .photo-card {
      order: -1;
      display: flex;
      justify-content: center;
      padding-top: 0.75rem;
    }
  }

  .photo-wrapper {
    --photo-card-width: 20rem;
    --gold-card-resting: rotate(4.5deg) translate(4px, 6px) scale(1.02);
    --gold-card-active: rotate(8deg) translate(8px, 10px) scale(1.04);
    width: min(100%, var(--photo-card-width));
    aspect-ratio: 5 / 6;
    cursor: pointer;
    transform-origin: center;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .photo-wrapper img {
    display: block;
    height: 100%;
    aspect-ratio: inherit;
  }

  @media (max-width: 720px) {
    .photo-wrapper {
      --photo-card-width: 12.5rem;
      --gold-card-resting: rotate(5deg) translate(3px, 2px) scale(1.04);
      --gold-card-active: rotate(10deg) translate(6px, 5px) scale(1.08);
    }
  }

  .gold-card {
    transform: var(--gold-card-resting);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: transform;
    backface-visibility: hidden;
  }

  .photo-wrapper.is-cycling .gold-card {
    animation: gold-card-mobile-cycle 1.3s both;
  }

  @keyframes gold-card-mobile-cycle {
    0% {
      transform: var(--gold-card-resting);
      animation-timing-function: cubic-bezier(0.18, 0.9, 0.24, 1);
    }

    52% {
      transform: var(--gold-card-active);
      animation-timing-function: cubic-bezier(0.42, 0, 0.18, 1);
    }

    100% {
      transform: var(--gold-card-resting);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .photo-wrapper:hover .gold-card {
      transform: var(--gold-card-active);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gold-card {
      transition: none;
    }

    .photo-wrapper.is-cycling .gold-card {
      animation: none;
      transform: var(--gold-card-active);
    }
  }

  .divider {
    height: 2px;
    width: 100%;
    background: linear-gradient(to right, var(--accent), transparent);
    border: none;
  }

  .availability-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .availability-dot {
      animation: none;
    }
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .contact-icon {
    display: none;
  }

  .contact-text-short {
    display: none;
  }

  .flex-break {
    display: none;
  }

  @media (max-width: 720px) {
    .contact-icon {
      display: block;
    }

    .contact-text {
      display: none;
    }

    .contact-text-short {
      display: inline;
    }

    .contact-sep {
      display: none;
    }

    .flex-break {
      flex-basis: 100%;
      height: 0;
    }
  }

  .email-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .tooltip {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--text);
    color: var(--bg);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .tooltip::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-bottom-color: var(--text);
  }

  .tooltip.show {
    opacity: 1;
  }
</style>

<script>
  const btn = document.getElementById('copy-email-hero');
  const tooltip = document.getElementById('copied-tooltip-hero');
  let timeout: ReturnType<typeof setTimeout>;

  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('cole.steele.dev@gmail.com');
    if (tooltip) tooltip.style.opacity = '1';
    clearTimeout(timeout);
    timeout = setTimeout(() => { if (tooltip) tooltip.style.opacity = '0'; }, 2000);
  });

  const photoWrapper = document.querySelector<HTMLElement>('[data-photo-wrapper]');
  const goldCard = photoWrapper?.querySelector<HTMLElement>('.gold-card');
  let photoCycleTimeout: ReturnType<typeof setTimeout>;

  const resetPhotoCycle = () => {
    photoWrapper?.classList.remove('is-cycling');
    clearTimeout(photoCycleTimeout);
  };

  const playPhotoCycle = (event?: PointerEvent | TouchEvent) => {
    const isTouchPointer = event && 'pointerType' in event && event.pointerType !== 'mouse';
    const isTouchDevice = window.matchMedia('(hover: none), (any-pointer: coarse)').matches;

    if (!photoWrapper || (!isTouchPointer && !isTouchDevice)) return;

    photoWrapper.classList.remove('is-cycling');
    photoWrapper.getBoundingClientRect();
    photoWrapper.classList.add('is-cycling');
    clearTimeout(photoCycleTimeout);
    photoCycleTimeout = setTimeout(resetPhotoCycle, 1400);
  };

  goldCard?.addEventListener('animationend', resetPhotoCycle);

  if ('PointerEvent' in window) {
    photoWrapper?.addEventListener('pointerup', playPhotoCycle);
    photoWrapper?.addEventListener('pointercancel', resetPhotoCycle);
  } else {
    photoWrapper?.addEventListener('touchend', playPhotoCycle);
    photoWrapper?.addEventListener('touchcancel', resetPhotoCycle);
  }
</script>
