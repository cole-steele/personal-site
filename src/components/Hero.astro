<section class="mt-16 grid grid-cols-2 gap-16 max-w-5xl mx-auto px-12 pb-12 items-center" id="main-content" tabindex="-1" aria-label="About">
  <div class="hero-text">
    <h1 class="font-display text-6xl font-black leading-tight text-[var(--text)]">
      Cole Steele
    </h1>
    <p class="text-lg text-[var(--muted)] mb-4 font-light">
      Software Engineer <span class="mx-2 opacity-40">|</span> Minneapolis, MN
    </p>
    <p class="text-sm text-[var(--muted)] leading-loose max-w-sm mb-6">
      I build web applications and have hands-on experience managing systems, networks, and devices in production environments. Currently working as an IT Specialist while actively seeking software engineering and IT roles.
    </p>
    <div class="flex items-center gap-2 mb-5">
      <span class="availability-dot"></span>
      <span class="text-xs text-green-500 font-medium">Open to work!</span>
    </div>

    <div class="divider mb-6"></div>

    <div class="flex items-center gap-3 flex-wrap">
      <div class="email-wrapper">
        <button
          id="copy-email-hero"
          aria-label="Copy email address to clipboard"
          class="text-sm text-[var(--muted)] hover:text-[var(--accent)] transition-colors duration-200 cursor-pointer bg-transparent border-none p-0"
        >
          cole.steele.dev@gmail.com
        </button>
        <div id="copied-tooltip-hero" class="tooltip" style="opacity: 0;" role="status" aria-live="polite">Copied!</div>
      </div>
      <span class="w-px h-4 bg-[var(--muted)] opacity-40" aria-hidden="true"></span>
      <a
        href="https://github.com/cole-steele"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile (opens in new tab)"
        class="text-sm text-[var(--muted)] hover:text-[var(--accent)] transition-colors duration-200"
      >
        GitHub
      </a>
      <span class="w-px h-4 bg-[var(--muted)] opacity-40" aria-hidden="true"></span>
      <a
        href="/resume.pdf"
        download
        class="rounded-full bg-[var(--accent)] px-4 py-1.5 text-xs font-medium text-white hover:opacity-90 transition-opacity duration-200"
      >
        Download Resume
      </a>
    </div>
  </div>

  <div class="photo-card">
    <div class="photo-wrapper relative w-80 flex-shrink-0">
      <div class="gold-card absolute inset-0 rounded-2xl bg-gradient-to-b from-[#e8b84b] to-[#c4922a] z-0"></div>
      <img
        src="/headshot.png"
        alt="Cole Steele"
        class="relative z-10 w-full h-96 rounded-2xl object-cover object-top"
      />
    </div>
  </div>
</section>

<style>
  @media (max-width: 720px) {
    section {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1.25rem 4rem;
    }

    .photo-card {
      order: -1;
      display: flex;
      justify-content: center;
    }
  }

  .gold-card {
    transform: rotate(4.5deg) translate(4px, 6px) scale(1.02);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .photo-wrapper:hover .gold-card {
    transform: rotate(8deg) translate(8px, 10px) scale(1.04);
  }

  .divider {
    height: 2px;
    width: 100%;
    background: linear-gradient(to right, var(--accent), transparent);
    border: none;
  }

  .availability-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .availability-dot {
      animation: none;
    }
  }

  .email-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .tooltip {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--text);
    color: var(--bg);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .tooltip::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-bottom-color: var(--text);
  }

  .tooltip.show {
    opacity: 1;
  }
</style>

<script>
  const btn = document.getElementById('copy-email-hero');
  const tooltip = document.getElementById('copied-tooltip-hero');
  let timeout: ReturnType<typeof setTimeout>;

  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('cole.steele.dev@gmail.com');
    if (tooltip) tooltip.style.opacity = '1';
    clearTimeout(timeout);
    timeout = setTimeout(() => { if (tooltip) tooltip.style.opacity = '0'; }, 2000);
  });
</script>
