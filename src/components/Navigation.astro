

<nav
  class="fixed top-0 z-100 w-full bg-[var(--bg)] transition-colors duration-300"
>
  <div class="flex items-center justify-between px-12 py-5">
    <a href="/" class="nav-logo">
      <div
        class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--text)] text-[var(--bg)] font-bold text-xs transition-colors duration-300"
      >
        CS
      </div>
      <span class="font-medium text-sm">Cole Steele</span>
    </a>

    <div class="flex items-center gap-4">
      <span class="text-xs font-medium uppercase tracking-wider text-[var(--accent)]">Contact</span>
      <div class="email-wrapper">
        <button
          id="copy-email"
          aria-label="Copy email address to clipboard"
          class="text-sm text-[var(--muted)] hover:text-[var(--accent)] transition-colors duration-200 cursor-pointer bg-transparent border-none p-0"
        >
          cole.steele.dev@gmail.com
        </button>
        <div id="copied-tooltip" class="tooltip" role="status" aria-live="polite">Copied!</div>
      </div>
      <a
        href="https://github.com/cole-steele"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile (opens in new tab)"
        class="text-sm text-[var(--muted)] hover:text-[var(--accent)] transition-colors duration-200"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-logo:hover {
    color: var(--accent);
  }

  .email-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .tooltip {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--text);
    color: var(--bg);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .tooltip::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-bottom-color: var(--text);
  }

  .tooltip.show {
    opacity: 1;
  }
</style>

<script>
  const btn = document.getElementById('copy-email');
  const tooltip = document.getElementById('copied-tooltip');
  let timeout: ReturnType<typeof setTimeout>;

  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('cole.steele.dev@gmail.com');
    tooltip?.classList.add('show');
    clearTimeout(timeout);
    timeout = setTimeout(() => tooltip?.classList.remove('show'), 2000);
  });
</script>
