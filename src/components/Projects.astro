---
import { projects } from '../data/projects';
---

<div class="max-w-5xl mx-auto px-12">
  <hr class="border-t border-[var(--bg2)] my-0" />
</div>

<section class="max-w-5xl mx-auto px-12 py-12" id="projects">
  <h2 class="text-xs font-medium uppercase tracking-wider text-[var(--accent)] mb-6">
    Projects
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    {projects.map((project) => (
      <a
        href={`/projects/${project.slug}`}
        class="project-card rounded-lg bg-[var(--card-bg)] overflow-hidden transition-all duration-200 hover:shadow-lg hover:-translate-y-1"
      >
        <div class={`thumbnail overflow-hidden${project.slug === 'personal-site' ? ' project-img-frame' : ''}`}>
          {project.image && (
            <img src={project.image} alt={`${project.name} preview`} class={project.imageClass ?? "w-full h-full object-cover object-center scale-125"} style={project.imageStyle} />
          )}
        </div>
        <div class="p-6">
        <div class="font-display text-lg font-bold text-[var(--text)] mb-2">{project.name}</div>
        <p class="text-sm text-[var(--muted)] leading-relaxed mb-4">{project.description}</p>
        <div class="flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="text-xs bg-[var(--bg2)] text-[var(--muted)] px-2 py-1 rounded-full">{tag}</span>
          ))}
        </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .project-card {
    display: block;
    text-decoration: none;
  }

  .thumbnail {
    width: 100%;
    height: 140px;
    background: var(--card-bg);
  }

  .project-img-frame {
    position: relative;
  }

  .project-img-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 35%, rgba(0,0,0,0.55) 100%);
  }

  @media (max-width: 720px) {
    section {
      padding: 2rem 1.25rem;
    }
  }
</style>
